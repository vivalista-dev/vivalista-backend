generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users  User[]
  events Event[]
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           Role     @default(STAFF)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  events Event[]
}

model Event {
  id             String   @id @default(uuid())
  title          String
  type           String
  slug           String   @unique
  description    String?
  eventDate      DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  userId         String
  user           User @relation(fields: [userId], references: [id])
}